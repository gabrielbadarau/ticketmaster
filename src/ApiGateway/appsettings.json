{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "events-route": {
        "ClusterId": "event-service",
        "Match": {
          "Path": "/events/{**catch-all}"
        }
      },
      "bookings-route": {
        "ClusterId": "booking-service",
        "Match": {
          "Path": "/bookings/{**catch-all}"
        }
      },
      "queue-route": {
        "ClusterId": "booking-service",
        "Match": {
          "Path": "/queue/{**catch-all}"
        }
      },
      "webhooks-route": {
        "ClusterId": "booking-service",
        "Match": {
          "Path": "/webhooks/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-service",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "event-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:05",
            "Timeout": "00:00:03",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Metadata": {
          "ConsecutiveFailuresHealthPolicy.Threshold": "2"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5049"
          }
        }
      },
      "booking-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:05",
            "Timeout": "00:00:03",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Metadata": {
          "ConsecutiveFailuresHealthPolicy.Threshold": "2"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5290"
          }
        }
      },
      "auth-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:05",
            "Timeout": "00:00:03",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Metadata": {
          "ConsecutiveFailuresHealthPolicy.Threshold": "2"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  }
}
